generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            BigInt                        @id @default(autoincrement())
  email                         String                        @unique
  password                      String
  role                          String                        @default("STANDARD")
  photoUrl                      String                        @default("")
  firstName                     String                        @default("")
  lastName                      String                        @default("")
  companyId                     BigInt?
  teamId                        BigInt?
  hasSeenOnboarding             Boolean                       @default(false)
  points                        Int                           @default(0)
  selectedBadgeId               BigInt?
  bannerUrl                     String                        @default("")
  welcomeEmailSent              Boolean                       @default(false)
  blacklistedPlaces             BlacklistedPlace[]
  companyStats                  CompanyStats?
  Event_Event_createdByIdToUser Event[]                       @relation("Event_createdByIdToUser")
  themeVotes                    EventThemeVote[]
  preferences                   EventUserPreference[]
  photos                        EventsUsersPhoto[]
  feedbacks                     Feedback[]
  notifications                 Notification[]
  PasswordResetToken            PasswordResetToken[]
  PointsHistory                 PointsHistory[]
  company                       Company?                      @relation(fields: [companyId], references: [id])
  Badge                         Badge?                        @relation(fields: [selectedBadgeId], references: [id])
  team                          Team?                         @relation(fields: [teamId], references: [id])
  UserBadge                     UserBadge[]
  votes                         Vote[]
  event_questionnaire_answers   event_questionnaire_answers[]
  events                        Event[]                       @relation("EventUsers")
}

model Company {
  id                BigInt             @id @default(autoincrement())
  name              String
  address           String?
  blacklistedPlaces BlacklistedPlace[]
  teams             Team[]
  users             User[]
}

model Team {
  id        BigInt   @id @default(autoincrement())
  name      String
  companyId BigInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
}

model Event {
  id                           BigInt                        @id @default(autoincrement())
  title                        String
  maxPersons                   BigInt?
  costPerPerson                BigInt?
  state                        String                        @default("PENDING")
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime
  uuid                         String                        @unique @default(uuid())
  city                         String?
  endDate                      DateTime?
  endTime                      DateTime?
  maxDistance                  Float?
  startDate                    DateTime?
  startTime                    DateTime?
  createdById                  BigInt?
  duration                     Int?
  recurring                    Boolean                       @default(false)
  recurringRate                String?
  isSpecificPlace              Boolean                       @default(false)
  confirmedGoogleTagId         BigInt?
  isPublic                     Boolean                       @default(false)
  publicStatus                 String                        @default("open")
  confirmedGoogleTagSubGroupId BigInt?                       @map("confirmed_google_tag_sub_group_id")
  description                  String                        @default("")
  date_known                   Boolean                       @default(true)
  category_id                  BigInt?
  blacklistedPlaces            BlacklistedPlace[]
  event_categories             event_categories?             @relation(fields: [category_id], references: [id])
  confirmedGoogleTag           GoogleTag?                    @relation("EventConfirmedGoogleTag", fields: [confirmedGoogleTagId], references: [id])
  confirmedGoogleTagSubGroup   GoogleTagSubGroup?            @relation("EventConfirmedGoogleTagSubGroup", fields: [confirmedGoogleTagSubGroupId], references: [id])
  User_Event_createdByIdToUser User?                         @relation("Event_createdByIdToUser", fields: [createdById], references: [id])
  location                     EventLocation?
  themeVotes                   EventThemeVote[]
  preferences                  EventUserPreference[]
  photos                       EventsUsersPhoto[]
  feedbacks                    Feedback[]
  notifications                Notification[]
  votes                        Vote[]
  event_place_proposals        event_place_proposals[]
  event_questionnaire_answers  event_questionnaire_answers[]
  selectedGoogleTagGroups      GoogleTagGroup[]              @relation("EventSelectedGoogleTagGroups")
  selectedGoogleTags           GoogleTag[]                   @relation("EventSelectedGoogleTags")
  users                        User[]                        @relation("EventUsers")
}

model GoogleTagGroup {
  id               BigInt              @id @default(autoincrement())
  name             String
  sortOrder        Int                 @default(0) @map("sort_order")
  isActive         Boolean             @default(true) @map("is_active")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  subGroups        GoogleTagSubGroup[]
  selectedByEvents Event[]             @relation("EventSelectedGoogleTagGroups")

  @@map("google_tag_groups")
}

model GoogleTagSubGroup {
  id                BigInt           @id @default(autoincrement())
  name              String
  groupId           BigInt           @map("group_id")
  sortOrder         Int              @default(0) @map("sort_order")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  confirmedOnEvents Event[]          @relation("EventConfirmedGoogleTagSubGroup")
  themeVotes        EventThemeVote[]
  group             GoogleTagGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tags              GoogleTag[]

  @@index([groupId, sortOrder])
  @@map("google_tag_sub_groups")
}

model GoogleTag {
  id                            BigInt                          @id @default(autoincrement())
  techName                      String                          @unique @map("tech_name")
  displayName                   String?                         @map("display_name")
  source                        String                          @default("google-docs")
  isActive                      Boolean                         @default(true) @map("is_active")
  createdAt                     DateTime                        @default(now()) @map("created_at")
  updatedAt                     DateTime                        @updatedAt @map("updated_at")
  sortOrder                     Int                             @default(0) @map("sort_order")
  subGroupId                    BigInt?                         @map("sub_group_id")
  confirmedOnEvents             Event[]                         @relation("EventConfirmedGoogleTag")
  category_question_option_tags category_question_option_tags[]
  subGroup                      GoogleTagSubGroup?              @relation(fields: [subGroupId], references: [id])
  selectedByEvents              Event[]                         @relation("EventSelectedGoogleTags")

  @@index([subGroupId, sortOrder])
  @@map("google_tags")
}

model EventUserPreference {
  userId        BigInt
  eventId       BigInt
  preferredDate DateTime
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@id([userId, eventId])
}

model EventThemeVote {
  userId              BigInt
  eventId             BigInt
  createdAt           DateTime          @default(now())
  googleTagSubGroupId BigInt            @map("google_tag_sub_group_id")
  event               Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  googleTagSubGroup   GoogleTagSubGroup @relation(fields: [googleTagSubGroupId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, eventId, googleTagSubGroupId])
  @@index([eventId, googleTagSubGroupId])
}

model EventsUsersPhoto {
  id        BigInt  @id @default(autoincrement())
  userId    BigInt
  eventId   BigInt
  photoUrl  String
  caption   String?
  createdAt BigInt
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  userId       BigInt
  eventId      BigInt
  rating       BigInt?
  message      String?
  createdAt    DateTime @default(now())
  participated Boolean?
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
}

model Vote {
  userId    BigInt
  eventId   BigInt
  total     BigInt
  createdAt DateTime
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
}

model EventLocation {
  eventId  BigInt  @unique
  id       BigInt  @id
  place_id String?
  name     String?
  address  String?
  lat      Float?
  lng      Float?
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model CompanyStats {
  superAdminId BigInt @id
  totalPersons BigInt
  subscription String
  price        BigInt
  companyName  String
  superAdmin   User   @relation(fields: [superAdminId], references: [id])
}

model PasswordResetToken {
  id        BigInt    @id @default(autoincrement())
  token     String    @unique @db.VarChar(255)
  email     String    @db.VarChar(255)
  userId    BigInt
  expiresAt DateTime  @db.Timestamp(6)
  used      Boolean?  @default(false)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token])
}

model BlacklistedPlace {
  id          BigInt   @id @default(autoincrement())
  placeId     String
  companyId   BigInt
  eventId     BigInt?
  createdById BigInt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([companyId, placeId])
  @@index([eventId, placeId])
  @@index([companyId, eventId])
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  message   String
  read      Boolean  @default(false)
  type      String?
  eventId   BigInt?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Badge {
  id             BigInt      @id @default(autoincrement())
  name           String      @unique
  description    String
  icon           String
  pointsRequired Int
  order          Int
  createdAt      DateTime    @default(now())
  User           User[]
  UserBadge      UserBadge[]

  @@index([pointsRequired])
}

model PointsHistory {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  points      Int
  action      String
  description String?
  eventId     BigInt?
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserBadge {
  userId     BigInt
  badgeId    BigInt
  unlockedAt DateTime @default(now())
  Badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([userId])
}

model PendingRegistration {
  id              String   @id @default(cuid())
  payload         Json
  stripeSessionId String?  @unique
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([stripeSessionId])
}

model category_question_option_tags {
  option_id                 BigInt
  tag_id                    BigInt
  category_question_options category_question_options @relation(fields: [option_id], references: [id], onDelete: Cascade)
  google_tags               GoogleTag                 @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([option_id, tag_id])
  @@index([tag_id])
}

model category_question_options {
  id                            BigInt                          @id @default(autoincrement())
  question_id                   BigInt
  label                         String
  weight                        Int                             @default(2)
  all_category_tags             Boolean                         @default(false)
  sort_order                    Int                             @default(0)
  category_question_option_tags category_question_option_tags[]
  category_questions            category_questions              @relation(fields: [question_id], references: [id], onDelete: Cascade)
  event_questionnaire_answers   event_questionnaire_answers[]

  @@index([question_id, sort_order])
}

model category_questions {
  id                        BigInt                      @id @default(autoincrement())
  category_id               BigInt
  text                      String
  sort_order                Int                         @default(0)
  multi_select              Boolean                     @default(false)
  max_choices               Int                         @default(1)
  is_active                 Boolean                     @default(true)
  created_at                DateTime                    @default(now())
  updated_at                DateTime                    @default(now())
  category_question_options category_question_options[]
  event_categories          event_categories            @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@index([category_id, sort_order])
}

model event_categories {
  id                 BigInt               @id @default(autoincrement())
  name               String               @unique
  slug               String               @unique
  sort_order         Int                  @default(0)
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @default(now())
  Event              Event[]
  category_questions category_questions[]
}

model event_place_proposals {
  id                 BigInt   @id @default(autoincrement())
  event_id           BigInt
  place_id           String
  name               String
  address            String
  rating             Float?
  user_ratings_total Int?
  photo_url          String?
  website_url        String?
  score              Float    @default(0)
  rank               Int
  chosen             Boolean  @default(false)
  created_at         DateTime @default(now())
  lat                Float?
  lng                Float?
  Event              Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([event_id, place_id])
  @@index([event_id, rank])
}

model event_questionnaire_answers {
  event_id                  BigInt
  user_id                   BigInt
  option_id                 BigInt
  created_at                DateTime                  @default(now())
  Event                     Event                     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  category_question_options category_question_options @relation(fields: [option_id], references: [id], onDelete: Cascade)
  User                      User                      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([event_id, user_id, option_id])
  @@index([event_id, option_id])
}
