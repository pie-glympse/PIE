generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            BigInt                      @id @default(autoincrement())
  email                         String                      @unique
  password                      String
  role                          String                      @default("STANDARD")
  photoUrl                      String                      @default("")
  firstName                     String                      @default("")
  lastName                      String                      @default("")
  companyId                     BigInt?
  teamId                        BigInt?
  hasSeenOnboarding             Boolean                     @default(false)
  points                        Int                         @default(0)
  selectedBadgeId               BigInt?
  bannerUrl                     String                      @default("")
  blacklistedPlaces             BlacklistedPlace[]
  companyStats                  CompanyStats?
  Event_Event_createdByIdToUser Event[]                     @relation("Event_createdByIdToUser")
  preferences                   EventUserPreference[]
  themeVotes                    EventThemeVote[]
  photos                        EventsUsersPhoto[]
  feedbacks                     Feedback[]
  notifications                 Notification[]
  PasswordResetToken            PasswordResetToken[]
  PointsHistory                 PointsHistory[]
  company                       Company?                    @relation(fields: [companyId], references: [id])
  Badge                         Badge?                      @relation(fields: [selectedBadgeId], references: [id])
  team                          Team?                       @relation(fields: [teamId], references: [id])
  UserBadge                     UserBadge[]
  votes                         Vote[]
  events                        Event[]                     @relation("EventUsers")
}

model Company {
  id                BigInt             @id @default(autoincrement())
  name              String
  blacklistedPlaces BlacklistedPlace[]
  teams             Team[]
  users             User[]
}

model Team {
  id        BigInt   @id @default(autoincrement())
  name      String
  companyId BigInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
}

model Event {
  id                           BigInt                      @id @default(autoincrement())
  title                        String
  maxPersons                   BigInt?
  costPerPerson                BigInt?
  state                        String                      @default("PENDING")
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime
  uuid                         String                      @unique @default(uuid())
  city                         String?
  endDate                      DateTime?
  endTime                      DateTime?
  maxDistance                  Float?
  startDate                    DateTime?
  startTime                    DateTime?
  createdById                  BigInt?
  duration                     Int?
  recurring                    Boolean                     @default(false)
  recurringRate                String?
  isSpecificPlace              Boolean                     @default(false)
  confirmedGoogleTagId         BigInt?
  blacklistedPlaces            BlacklistedPlace[]
  User_Event_createdByIdToUser User?                       @relation("Event_createdByIdToUser", fields: [createdById], references: [id])
  location                     EventLocation?
  preferences                  EventUserPreference[]
  themeVotes                   EventThemeVote[]
  photos                       EventsUsersPhoto[]
  feedbacks                    Feedback[]
  notifications                Notification[]
  votes                        Vote[]
  selectedGoogleTags           GoogleTag[]                 @relation("EventSelectedGoogleTags")
  confirmedGoogleTag           GoogleTag?                  @relation("EventConfirmedGoogleTag", fields: [confirmedGoogleTagId], references: [id])
  users                        User[]                      @relation("EventUsers")
}

model GoogleTag {
  id          BigInt   @id @default(autoincrement())
  techName    String   @unique @map("tech_name")
  displayName String?  @map("display_name")
  source      String   @default("google-docs")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  selectedByEvents Event[]         @relation("EventSelectedGoogleTags")
  confirmedOnEvents Event[]        @relation("EventConfirmedGoogleTag")
  themeVotes       EventThemeVote[]

  @@map("google_tags")
}

model EventUserPreference {
  userId         BigInt
  eventId        BigInt
  preferredDate  DateTime
  event          Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User  @relation(fields: [userId], references: [id])

  @@id([userId, eventId])
}

model EventThemeVote {
  userId     BigInt
  eventId    BigInt
  googleTagId BigInt
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  googleTag   GoogleTag @relation(fields: [googleTagId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, eventId, googleTagId])
  @@index([eventId, googleTagId])
}

model EventsUsersPhoto {
  id        BigInt  @id @default(autoincrement())
  userId    BigInt
  eventId   BigInt
  photoUrl  String
  caption   String?
  createdAt BigInt
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  userId       BigInt
  eventId      BigInt
  rating       BigInt?
  message      String?
  createdAt    DateTime @default(now())
  participated Boolean?
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
}

model Vote {
  userId    BigInt
  eventId   BigInt
  total     BigInt
  createdAt DateTime
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
}

model EventLocation {
  eventId BigInt @unique
  id      BigInt @id
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model CompanyStats {
  superAdminId BigInt @id
  totalPersons BigInt
  subscription String
  price        BigInt
  companyName  String
  superAdmin   User   @relation(fields: [superAdminId], references: [id])
}

model PasswordResetToken {
  id        BigInt    @id @default(autoincrement())
  token     String    @unique @db.VarChar(255)
  email     String    @db.VarChar(255)
  userId    BigInt
  expiresAt DateTime  @db.Timestamp(6)
  used      Boolean?  @default(false)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token])
}

model BlacklistedPlace {
  id          BigInt   @id @default(autoincrement())
  placeId     String
  companyId   BigInt
  eventId     BigInt?
  createdById BigInt
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([companyId, placeId])
  @@index([eventId, placeId])
  @@index([companyId, eventId])
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  message   String
  read      Boolean  @default(false)
  type      String?
  eventId   BigInt?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Badge {
  id             BigInt      @id @default(autoincrement())
  name           String      @unique
  description    String
  icon           String
  pointsRequired Int
  order          Int
  createdAt      DateTime    @default(now())
  User           User[]
  UserBadge      UserBadge[]

  @@index([pointsRequired])
}

model PointsHistory {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  points      Int
  action      String
  description String?
  eventId     BigInt?
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserBadge {
  userId     BigInt
  badgeId    BigInt
  unlockedAt DateTime @default(now())
  Badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([userId])
}
