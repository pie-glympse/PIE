# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
react-email-starter/node_modules
/.pnp
.pnp.*

# react-email build artifact (regenerated by `email build`/`email dev`)
react-email-starter/.react-email
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Uploads
public/uploads/*
!public/uploads/.gitkeep

# Prisma
prisma/migrations/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.agents/
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

#Vs code
.idea

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
